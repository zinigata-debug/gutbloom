{
  "expo": {
    "name": "GutBloom",
    "slug": "gutly",
    "version": "1.0.0",
    "scheme": "gutly",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gutly.app"
    },
    "android": {
      "package": "com.gutly.app",
      "adaptiveIcon": {
        "backgroundColor": "#e3f2e1",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "GutBloom needs camera access to scan food barcodes and photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#e7f3df"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "06a91f2b-c11a-411b-92bc-666c9a4e2661"
      }
    },
    "owner": "zinigata"
  }
}
